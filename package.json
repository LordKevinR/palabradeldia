{
  "name": "palabra-del-dia",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "nodemon api/index.js",
    "build": "vite build",
    "start": "node api/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{js,jsx,css}\" \"api/**/*.js\""
  },
  "dependencies": {
    "@libsql/client": "^0.17.4",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.2",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "lucide-react": "^0.395.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitejs/plugin-legacy": "^5.4.1",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^8.2.2",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "nodemon": "^3.1.2",
    "prettier": "^3.9.4",
    "terser": "^5.31.0",
    "vite": "^5.2.11",
    "vitest": "^4.1.10"
  }
}
